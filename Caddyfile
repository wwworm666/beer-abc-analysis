beerkultura.ru {
	encode gzip

	# Кэширование статики на стороне клиента. Ассеты версионируются ?v=<hash>,
	# поэтому длинный max-age безопасен (новая версия = новый URL).
	@static path /static/*
	header @static Cache-Control "public, max-age=2592000"

	reverse_proxy localhost:10000

	log {
		output file /data/access.log {
			roll_size 10mb
			roll_keep 5
		}
		format console
	}
}

# www → apex редирект (Caddy сам выпустит второй LE-сертификат)
www.beerkultura.ru {
	redir https://beerkultura.ru{uri} permanent
}
