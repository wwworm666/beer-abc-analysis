# iiko REST API
IIKO_SERVER=first-federation.iiko.it
IIKO_PORT=443
IIKO_LOGIN=your_login
IIKO_PASSWORD=your_password

# Telegram бот (webhook режим)
TELEGRAM_BOT_TOKEN=

# Удалённый бар-ПК (доступен через Tailscale)
REMOTE_USER=Администратор
REMOTE_HOST=100.98.149.108
REMOTE_PASS=

# Расписание ежедневного авторефреша ЧЗ (только если REMOTE_PASS задан)
CHZ_REFRESH_HOUR=3
CHZ_REFRESH_MINUTE=0

# Публичный URL приложения (без trailing /)
# Используется scheduler'ом для самовызовов и при формировании ссылок
API_BASE_URL=https://your-domain.example

# Домен для Caddy reverse-proxy (без https://, без слеша)
APP_DOMAIN=your-domain.example

# Путь к persistent-данным внутри контейнера (не менять без правок extensions.py)
PERSISTENT_DATA_DIR=/kultura
