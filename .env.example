# Авторизация
# SECRET_KEY — ключ подписи сессионных cookie. Можно НЕ задавать: тогда он
# генерируется один раз в {/kultura|data}/secret_key и переживает редеплой.
# Если задаёшь явно — НЕ меняй потом без причины (смена разлогинит всех).
SECRET_KEY=
# Первый владелец (admin). Можно оставить пустым и создать через форму на /login
# при первом заходе. Если заданы оба — создаётся на первом старте.
AUTH_BOOTSTRAP_LOGIN=
AUTH_BOOTSTRAP_PASSWORD=
AUTH_BOOTSTRAP_NAME=
# Secure-флаг cookie. По умолчанию авто: True на проде (есть /kultura), False
# локально по http. Переопределять обычно не нужно.
SESSION_COOKIE_SECURE=

# iiko REST API
IIKO_SERVER=first-federation.iiko.it
IIKO_PORT=443
IIKO_LOGIN=your_login
IIKO_PASSWORD=your_password

# Telegram — основной бот (аналитика, ABC и т.п.)
TELEGRAM_BOT_TOKEN=

# Telegram — open-check бот (проверка открытых смен в 14:59 МСК)
TELEGRAM_OPEN_CHECK_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=
TELEGRAM_ALARM_CHAT_IDS=

# Удалённый бар-ПК (доступен через Tailscale)
REMOTE_USER=Администратор
REMOTE_HOST=100.98.149.108
REMOTE_PASS=

# Scheduler — ежедневный авторефреш ЧЗ
CHZ_REFRESH_HOUR=3
CHZ_REFRESH_MINUTE=0

# Scheduler — open-check (расписание дефолтное 14:59, не трогать без причины)
OPEN_CHECK_HOUR=14
OPEN_CHECK_MINUTE=59

# Публичный URL приложения (без trailing /)
API_BASE_URL=https://your-domain.example
APP_DOMAIN=your-domain.example

# Cosplay Render: код в routes/open_check.py и routes/misc.py читает
# RENDER_EXTERNAL_URL для авто-base_url при setup-webhook. Дублируем тот же домен.
RENDER_EXTERNAL_URL=https://your-domain.example

# Путь к persistent-данным внутри контейнера (не менять без правок extensions.py)
PERSISTENT_DATA_DIR=/kultura
