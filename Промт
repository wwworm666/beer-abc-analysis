function analyzeBarMetricsWithPro() {
  const API_KEY = 'YOUR_GEMINI_API_KEY';
  const MODEL = 'gemini-2.5-pro';  // 🎯 Используем Pro версию
  
  const url = `https://generativelanguage.googleapis.com/v1beta/models/${MODEL}:generateContent?key=${API_KEY}`;
  
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Дашборд');
  
  // Получаем период анализа
  const periodName = sheet.getRange('A1').getValue() || 'текущий период';
  
  // Собираем все метрики
  const metrics = {
    период: periodName,
    
    // Основные показатели
    выручка: {
      план: sheet.getRange('B2').getValue(),
      факт: sheet.getRange('B3').getValue()
    },
    чеки: {
      план: sheet.getRange('D2').getValue(),
      факт: sheet.getRange('D3').getValue()
    },
    средний_чек: {
      план: sheet.getRange('F2').getValue(),
      факт: sheet.getRange('F3').getValue()
    },
    
    // Структура выручки
    розлив: {
      доля_план: sheet.getRange('B5').getValue(),
      доля_факт: sheet.getRange('B6').getValue(),
      выручка_план: sheet.getRange('B7').getValue(),
      выручка_факт: sheet.getRange('B8').getValue(),
      наценка_план: sheet.getRange('B9').getValue(),
      наценка_факт: sheet.getRange('B10').getValue()
    },
    фасовка: {
      доля_план: sheet.getRange('D5').getValue(),
      доля_факт: sheet.getRange('D6').getValue(),
      выручка_план: sheet.getRange('D7').getValue(),
      выручка_факт: sheet.getRange('D8').getValue(),
      наценка_план: sheet.getRange('D9').getValue(),
      наценка_факт: sheet.getRange('D10').getValue()
    },
    кухня: {
      доля_план: sheet.getRange('F5').getValue(),
      доля_факт: sheet.getRange('F6').getValue(),
      выручка_план: sheet.getRange('F7').getValue(),
      выручка_факт: sheet.getRange('F8').getValue(),
      наценка_план: sheet.getRange('F9').getValue(),
      наценка_факт: sheet.getRange('F10').getValue()
    }
  };
  
  // Промпт для Pro версии (более детальный)
  const prompt = `
Ты опытный финансовый аналитик сети пивных баров "Культура", которая работает 8 лет.

Специализация бара:
- Пиво на розлив (основная категория)
- Фасованное пиво (высокая маржа)
- Кухня: римская пицца, колбасы собственного производства

ДАННЫЕ ЗА ПЕРИОД: ${periodName}

МЕТРИКИ:
${JSON.stringify(metrics, null, 2)}

ЗАДАЧА - ГЛУБОКИЙ АНАЛИЗ:

1. 🔴 КРИТИЧЕСКИЕ ПРОБЛЕМЫ
   Для каждой проблемы укажи:
   - Конкретное отклонение (цифры и %)
   - Финансовое влияние (сколько теряем рублей)
   - Вероятную причину
   - Взаимосвязь с другими метриками

2. 💡 ПРИОРИТИЗИРОВАННЫЕ РЕКОМЕНДАЦИИ
   Для каждой рекомендации:
   - Конкретное действие (не "улучшить", а "что именно делать")
   - Ожидаемый эффект (на сколько % вырастет метрика)
   - Зона ответственности (персонал/менеджмент/закупки)
   - Срочность (сделать сегодня/на неделе/в этом месяце)

3. 📊 СКРЫТЫЕ ЗАКОНОМЕРНОСТИ
   - Какие метрики коррелируют
   - Неочевидные взаимосвязи
   - Тренды (если есть паттерн)

4. 📈 ПРОГНОЗ И РИСКИ
   - Прогноз на конец периода при текущих темпах
   - Риски невыполнения плана (в рублях)
   - Возможности для роста

ФОРМАТ ОТВЕТА:
- Максимум 1500 символов
- Конкретные цифры в каждом пункте
- Используй эмодзи для структуры
- Никакой воды, только практичные инсайты

Начинай анализ:
`;

  const payload = {
    contents: [{
      parts: [{
        text: prompt
      }]
    }],
    generationConfig: {
      temperature: 0.4,        // Ниже для большей точности
      maxOutputTokens: 4096,   // Больше для детального анализа
      topP: 0.95,
      topK: 40
    },
    // Можно добавить system instruction для 2.5 Pro
    systemInstruction: {
      parts: [{
        text: "Ты - эксперт по финансовому анализу HoReCa бизнеса с 15-летним опытом. Специализируешься на барах и ресторанах. Всегда даёшь конкретные, измеримые рекомендации с расчётом финансового эффекта."
      }]
    }
  };
  
  const options = {
    method: 'post',
    contentType: 'application/json',
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  };
  
  try {
    Logger.log('🔄 Отправляю запрос к Gemini 2.5 Pro...');
    
    const response = UrlFetchApp.fetch(url, options);
    const json = JSON.parse(response.getContentText());
    
    if (json.candidates && json.candidates[0]) {
      const analysis = json.candidates[0].content.parts[0].text;
      
      // Записываем результат
      const timestamp = new Date().toLocaleString('ru-RU');
      sheet.getRange('A10').setValue(analysis);
      sheet.getRange('A9').setValue(`🤖 AI Анализ (Gemini 2.5 Pro): ${timestamp}`);
      
      // Логируем использование токенов
      if (json.usageMetadata) {
        const tokens = json.usageMetadata;
        Logger.log(`✅ Анализ получен`);
        Logger.log(`📊 Использовано токенов: ${tokens.totalTokenCount}`);
        Logger.log(`   └─ Input: ${tokens.promptTokenCount}`);
        Logger.log(`   └─ Output: ${tokens.candidatesTokenCount}`);
      }
      
      return analysis;
      
    } else if (json.error) {
      const errorMsg = json.error.message;
      Logger.log(`❌ Ошибка API: ${errorMsg}`);
      
      // Обработка распространённых ошибок
      if (errorMsg.includes('RATE_LIMIT_EXCEEDED')) {
        sheet.getRange('A10').setValue('⚠️ Превышен лимит запросов. Попробуйте через 30 секунд.');
      } else if (errorMsg.includes('QUOTA_EXCEEDED')) {
        sheet.getRange('A10').setValue('⚠️ Исчерпан дневной лимит (50 запросов). Попробуйте завтра.');
      } else {
        sheet.getRange('A10').setValue(`❌ Ошибка: ${errorMsg}`);
      }
      
      return null;
    }
    
  } catch (error) {
    Logger.log(`❌ Ошибка запроса: ${error}`);
    sheet.getRange('A10').setValue(`❌ Ошибка соединения: ${error}`);
    return null;
  }
}

// Функция для множественных анализов с задержкой
function runMultipleAnalyses() {
  // Анализ 1
  analyzeBarMetricsWithPro();
  
  // Ждём 30 секунд (чтобы не превысить 2 RPM)
  Utilities.sleep(30000);
  
  // Анализ 2 (например, для другого периода)
  // Здесь можно изменить диапазон данных
  analyzeBarMetricsWithPro();
}

// Функция для проверки оставшихся запросов (примерная)
function checkUsageToday() {
  const props = PropertiesService.getScriptProperties();
  const today = new Date().toDateString();
  const lastDate = props.getProperty('lastRequestDate');
  let requestCount = parseInt(props.getProperty('requestCount') || '0');
  
  // Сброс счётчика в новый день
  if (lastDate !== today) {
    requestCount = 0;
    props.setProperty('lastRequestDate', today);
  }
  
  props.setProperty('requestCount', (requestCount + 1).toString());
  
  Logger.log(`📊 Запросов сегодня: ${requestCount + 1}/50`);
  
  if (requestCount >= 49) {
    Logger.log('⚠️ Предупреждение: близко к дневному лимиту!');
  }
}